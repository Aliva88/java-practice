
      var1.push(140);
      var1.push(150);
      var1.push(160);
      System.out.println("Is Empty: " + var1.isEmpty());
      System.out.println("Is Full: " + var1.isFull());
      System.out.println("Top element: " + var1.peek());
      System.out.println("Delet element: " + var1.pop());
      System.out.println("Top element: " + var1.peek());
      System.out.println("Is Full: " + var1.isFull());
   }
}
